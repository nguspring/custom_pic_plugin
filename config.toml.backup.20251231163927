# custom_pic_plugin - 自动生成的配置文件
# 智能多模型图片生成插件，支持文生图和图生图自动识别。兼容OpenAI、豆包、Gemini、魔搭等多种API格式。提供命令式风格转换、模型配置管理、结果缓存等功能。支持动态模型切换、风格别名、调试开关等高级特性。

# ConfigSection(title='插件启用配置', description=None, icon='info', collapsed=False, order=1)
[plugin]

# 智能多模型图片生成插件，支持文生图/图生图自动识别 (必需)
name = "custom_pic_plugin"

# 插件配置版本号
config_version = "3.3.3"

# 是否启用插件，开启后可使用画图和风格转换功能
enabled = true


# ConfigSection(title='图片生成默认配置', description=None, icon='image', collapsed=False, order=2)
[generation]

# 默认使用的模型ID，用于智能图片生成。支持文生图和图生图自动识别
default_model = "model1"


# ConfigSection(title='结果缓存配置', description=None, icon='database', collapsed=False, order=5)
[cache]

# 是否启用结果缓存，相同参数的请求会复用之前的结果
enabled = false

# 最大缓存数量，超出后删除最旧的缓存
max_size = 10


# ConfigSection(title='组件启用配置', description=None, icon='puzzle-piece', collapsed=False, order=3)
[components]

# 是否启用智能图片生成Action，支持文生图和图生图自动识别
enable_unified_generation = true

# 是否启用风格化图生图Command功能，支持/dr <风格>命令
enable_pic_command = true

# 是否启用模型配置管理命令，支持/dr list、/dr set等
enable_pic_config = true

# 是否启用风格管理命令，支持/dr styles、/dr style等
enable_pic_style = true

# Command组件使用的模型ID，可通过/dr set命令动态切换
pic_command_model = "model1"

# 是否启用调试信息显示，关闭后仅显示图片结果和错误信息
enable_debug_info = false

# 是否启用详细调试信息，启用后会发送完整的调试信息以及打印完整的 POST 报文
enable_verbose_debug = false

# 有权限使用配置管理命令的管理员用户列表，请填写字符串形式的用户ID
admin_users = ["NGU-SprinG"]

# API调用失败时的重试次数，建议2-5次。设置为0表示不重试
max_retries = 2


# ConfigSection(title='日志配置', description=None, icon='file-text', collapsed=True, order=11)
[logging]

# 日志记录级别，DEBUG显示详细信息
# 可选值: DEBUG, INFO, WARNING, ERROR
level = "INFO"

# 日志前缀标识
prefix = "[unified_pic_Plugin]"


# ConfigSection(title='代理设置', description=None, icon='globe', collapsed=False, order=4)
[proxy]

# 是否启用代理。开启后所有API请求将通过代理服务器
enabled = false

# 代理服务器地址，格式：http://host:port。支持HTTP/HTTPS/SOCKS5代理
url = "http://127.0.0.1:7890"

# 代理连接超时时间（秒），建议30-120秒
timeout = 60


# ConfigSection(title='风格定义', description='预设风格的提示词。添加更多风格请直接编辑 config.toml，格式：风格英文名 = "提示词"', icon='palette', collapsed=False, order=9)
[styles]

# 配置说明
hint = "添加更多风格：编辑 config.toml，在 [styles] 节下添加 风格英文名 = \"提示词\""

# 卡通风格提示词
cartoon = "2D anime character illustration, clean line art, game character art style, anime cel shading, character design, front view portrait, anime face, stylized proportions, colorful, vibrant colors, clean lines"

reality = "photorealistic, professional photography, realistic details, soft natural light, cinematic lighting, proper leg anatomy, realistic proportions, intricate fabric textures"

# ConfigSection(title='风格别名', description='风格的中文别名映射。添加更多别名请直接编辑 config.toml', icon='tag', collapsed=False, order=10)
[style_aliases]

# 配置说明
hint = "添加更多别名：编辑 config.toml，在 [style_aliases] 节下添加 风格英文名 = \"中文别名\""

# cartoon 风格的中文别名，支持多别名用逗号分隔
cartoon = "卡通, 二次元"

reality = "现实， 真实"

# ConfigSection(title='自拍模式配置', description=None, icon='camera', collapsed=False, order=6)
[selfie]

# 是否启用自拍模式功能
enabled = true

# 自拍参考图片路径（相对于插件目录或绝对路径）。配置后自动使用图生图模式，留空则使用纯文生图。若模型不支持图生图会自动回退
reference_image_path = ""

# 自拍模式专用提示词前缀。用于添加Bot的默认形象特征（发色、瞳色、服装风格等）。例如：'blue hair, red eyes, school uniform, 1girl'
prompt_prefix = "photorealistic selfie portrait of a confident cute Chinese 18-year-old girl, athletic petite build, vibrant fiery short red hair outward-swept twin tails with golden ornaments, warm golden eyes, bright determined smile, slight head tilt, standing on both feet, stable pose, close-up perspective, white Gothic Lolita dress with black lace and ribbon details, white over-the-knee stockings, black ankle boots, highly detailed face, narrow jawline, pointed chin, intricate fabric textures, soft natural light, cinematic lighting, 8k, sharp focus, professional photography, proper leg anatomy, two legs only"


# ConfigSection(title='自动撤回配置', description=None, icon='trash', collapsed=False, order=7)
[auto_recall]

# 是否启用自动撤回功能（总开关）。关闭后所有模型的撤回都不生效
enabled = false


# ConfigSection(title='提示词优化器', description='使用 MaiBot 主 LLM 将用户描述优化为专业绘画提示词', icon='wand-2', collapsed=False, order=8)
[prompt_optimizer]

# 是否启用提示词优化器。开启后会使用 MaiBot 主 LLM 将用户描述优化为专业英文提示词
enabled = true

# 功能说明
hint = "优化器会自动将中文描述翻译并优化为专业的英文绘画提示词，提升生成效果。关闭后将直接使用用户原始描述。"


# ConfigSection(title='多模型配置', description='添加更多模型请直接编辑 config.toml，复制 [models.model1] 整节并改名为 model2、model3 等', icon='cpu', collapsed=False, order=12)
[models]

# 配置说明
hint = "添加更多模型：编辑 config.toml，复制 [models.model1] 整节并改名为 model2、model3 等"


# ConfigSection(title='模型1配置', description=None, icon='box', collapsed=False, order=13)
[models.model1]

# 模型显示名称，在模型列表中展示，版本更新后请手动从 old 目录恢复配置
name = "Tongyi-MAI/Z-Image-Turbo"

# API服务地址。示例: OpenAI=https://api.openai.com/v1, 硅基流动=https://api.siliconflow.cn/v1, 豆包=https://ark.cn-beijing.volces.com/api/v3, 魔搭=https://api-inference.modelscope.cn/v1, Gemini=https://generativelanguage.googleapis.com (必需)
base_url = "https://api-inference.modelscope.cn/v1"

# API密钥。OpenAI/modelscope格式需'Bearer '前缀，豆包/Gemini格式无需前缀 (必需)
api_key = "Bearer ms-088ccf47-9cd9-4a2d-9cf0-0fe96e694ca1"

# API格式。openai=通用格式，doubao=豆包，gemini=Gemini，modelscope=魔搭，shatangyun=砂糖云(NovelAI)，mengyuai=梦羽AI，zai=Zai(Gemini转发)
# 可选值: openai, gemini, doubao, modelscope, shatangyun, mengyuai, zai
format = "modelscope"

# 模型名称。梦羽AI格式填写模型索引数字（如0、1、2）
model = "Tongyi-MAI/Z-Image-Turbo"

# 是否固定图片尺寸。开启后强制使用default_size，关闭则麦麦选择
fixed_size_enabled = false

# 默认图片尺寸。OpenAI/豆包/魔搭格式填写如 1024x1024。Gemini格式填写宽高比如 16:9 或 16:9-2K，具体参考官方文档
default_size = "1024x1024"

# 随机种子，固定值可确保结果可复现
seed = -1

# 指导强度。豆包推荐5.5，其他推荐2.5。越高越严格遵循提示词
guidance_scale = 2.5

# 推理步数，影响质量和速度。推荐20-50
num_inference_steps = 20

# 是否添加水印，豆包默认支持
watermark = false

# 正面提示词增强，自动添加到用户描述后
custom_prompt_add = ""

# 负面提示词，避免不良内容。豆包可留空但需保留引号
negative_prompt_add = "low quality, worst quality, bad quality, lowres, blurry, text, watermark, signature, extra arms, extra legs, extra hands, extra fingers, extra toes, missing fingers, bad anatomy, bad hands, bad proportions, extra thighs, extra calves, leg duplication, leg artifacts"

# 艺术家风格标签（砂糖云专用）。留空则不添加
artist = ""

# 该模型是否支持图生图功能，请根据API文档自行判断。设为false时会自动降级为文生图
support_img2img = true

# 自动撤回延时（秒）。大于0时启用撤回，0表示不撤回。需先在「自动撤回配置」中开启总开关
auto_recall_delay = 0


